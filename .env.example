# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Chat model used by /api/anna. Change anytime without a code edit — set this
# in Vercel and redeploy. Defaults to claude-opus-4-7 if unset.
ANNA_MODEL=claude-opus-4-7

# Optional: public site URL used for CORS on the /api/anna proxy
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Upstash Redis — used to rate-limit the /api/anna chat proxy and /api/leads.
# Create a free database at https://console.upstash.com/ and copy the REST URL + token.
# If unset, rate limiting is DISABLED (a warning is logged in production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: broker CRM webhook. When set, each captured lead is POSTed here as
# JSON after it is saved. If unset, leads are stored in Supabase only.
LEADS_WEBHOOK=
